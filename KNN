data <- read.csv("test_scores.csv", stringsAsFactors = TRUE)
data

library(class)
library(gmodels)

data

normalize <- function(x) {                  #telling R you wish to take in a function x
  return ((x - min(x)) / (max(x) - min(x))) #that is going return x minimize the range divided by the maximum, minimize by the minimum
}

data_n <- as.data.frame(lapply(data[1:6], normalize))
data_n
summary(data_n)
#_______________________________________________________________________________

data_train <- data_n[1:1066, ]
data_test <- data_n[1067:2132, ]

data_train_grades <- data[1:1066, 9]
data_test_grades <- data[1067:2132, 9]

gradek3 <- knn(data_train, data_test, data_train_grades, k= 3)
CrossTable(x = data_train_grades, y = gradek3, prop.chisq = FALSE)
(365) * 100 / 1066
#34.24%
