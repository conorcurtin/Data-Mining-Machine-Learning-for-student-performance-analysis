#POSTTEST

#K-MEANS 3
data_train_posttest <- data[1:1066, 7]
data_test_posttest <- data[1067:2132, 7]
kmeans3 <- knn(data_train, data_test, data_train_posttest, k= 3)
CrossTable(x = data_test_posttest, y = kmeans3, prop.chisq = FALSE)
summary(kmeans3)
(51) * 100 / 1066 #4.78%
ct <- CrossTable(x = data_test_posttest, y = kmeans3, prop.chisq = FALSE)
# t: An n by m matrix containing table cell counts
ct_t <- ct[["t"]]
write.csv(ct_t,"ct_t.csv")
# prop.row: An n by m matrix containing cell row proportions
ct_row <- ct[["prop.row"]]
write.csv(ct_row,"ct_row.csv")
# prop.col: An n by m matrix containing cell column proportions
ct_col <- ct[["prop.col"]]
write.csv(ct_col,"ct_col.csv")
# prop.tbl: An n by m matrix containing cell table proportions
ct_tbl <- ct[["prop.tbl"]]
write.csv(ct_tbl,"ct_tbl.csv")


